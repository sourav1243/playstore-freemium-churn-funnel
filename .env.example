# Kaggle API credentials (optional - only needed for live Play Store data)
# Get yours at: https://www.kaggle.com/settings
KAGGLE_USERNAME=your_username
KAGGLE_KEY=your_key

# Random seed for reproducible synthetic data generation
RANDOM_SEED=42

# Simulation parameters (overrides config/simulation_config.yaml)
NUM_INSTALLS=120000
WEEKS_HISTORY=16

# Deployment settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
